---
import { Icon } from "astro-icon/components";
import { fetchAchievements } from "../services/fetchAchievements";

const achievements = await fetchAchievements();

// Sort by date (newest first)
const sortedAchievements = [...achievements].sort(
  (a, b) => new Date(b.achievedAt ?? "").getTime() - new Date(a.achievedAt ?? "").getTime()
);
---

<div class="max-w-6xl mx-auto px-4">
  <div class="flex items-center gap-4 mb-16">
    <h2 class="text-4xl font-black text-neutral-900 flex items-center gap-4">実績ギャラリー</h2>
    <div class="flex-grow h-px bg-gradient-to-r from-neutral-200 to-transparent"></div>
  </div>

  {
    sortedAchievements.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {sortedAchievements.map(achievement => (
          <a href={`/achievements/${achievement.id}`} class="group relative mt-8">
            <article class="relative h-full pt-12 px-8 pb-10 bg-white/70 backdrop-blur-xl border border-neutral-200/80 rounded-[3rem] hover:border-secondary-400/50 hover:shadow-[0_20px_50px_rgba(0,0,0,0.05)] hover:-translate-y-2 transition-all duration-700 flex flex-col items-center text-center">
              {/* 背景の常時発光 */}
              <div class="absolute -top-10 -right-10 w-40 h-40 bg-secondary-200/20 blur-[80px] rounded-full group-hover:bg-secondary-300/40 transition-all duration-700" />

              {/* メダルバッジ（存在感を強化） */}
              <div class="absolute -top-10 left-1/2 -translate-x-1/2 w-24 h-24 flex items-center justify-center">
                {/* バッジ背後のハロー（後光）エフェクト */}
                <div class="absolute inset-0 bg-secondary-400/20 blur-2xl rounded-full scale-110 group-hover:scale-150 group-hover:bg-secondary-400/40 transition-all duration-700" />

                {/* バッジ本体 */}
                <div class="relative w-20 h-20 bg-gradient-to-tr from-secondary-600 via-secondary-500 to-secondary-400 rounded-[2rem] flex items-center justify-center text-white shadow-[0_10px_30px_-5px_rgba(var(--color-secondary-600),0.5)] group-hover:scale-110 group-hover:-rotate-12 transition-all duration-500 z-20 overflow-hidden">
                  <Icon name="mdi:medal-outline" class="w-10 h-10 relative z-10" />
                  {/* バッジ内の光沢エフェクト */}
                  <div class="absolute top-0 left-0 w-full h-1/2 bg-white/20 -skew-y-12 -translate-y-full group-hover:translate-y-full transition-transform duration-1000" />
                </div>
              </div>

              <div class="mt-4 w-full">
                <time class="text-[10px] font-black text-secondary-500/60 uppercase tracking-[0.3em] mb-4 block">
                  {new Date(achievement.achievedAt ?? "").toLocaleDateString("ja-JP", {
                    year: "numeric",
                    month: "long",
                  })}
                </time>

                <h3 class="text-xl font-bold text-neutral-900 mb-4 group-hover:text-secondary-600 transition-colors leading-tight line-clamp-2">
                  {achievement.title}
                </h3>

                <div class="w-8 h-1 bg-secondary-100 mx-auto mb-6 rounded-full group-hover:w-16 group-hover:bg-secondary-200 transition-all duration-500" />

                <div class="inline-flex items-center gap-2 text-[10px] font-black text-neutral-300 group-hover:text-secondary-500 transition-colors uppercase tracking-[0.2em]">
                  View Detail Story
                  <Icon
                    name="mdi:chevron-right"
                    class="w-4 h-4 group-hover:translate-x-1 transition-transform"
                  />
                </div>
              </div>
            </article>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-20 bg-white/50 backdrop-blur-sm rounded-[3rem] border border-neutral-100">
        <p class="text-neutral-400 font-bold">まだ登録されている実績はありません。</p>
      </div>
    )
  }
</div>
