---
import { Icon } from "astro-icon/components";
import { fetchBackgrounds } from "../services/fetchBackgrounds";

const backgrounds = await fetchBackgrounds();

// 日付でソート (降順)
const sortedBackgrounds = [...backgrounds].sort(
  (a, b) => new Date(b.eventDate).getTime() - new Date(a.eventDate).getTime()
);
---

<div class="max-w-4xl mx-auto">
  <div class="flex items-center gap-4 mb-12">
    <h2 class="text-3xl font-black text-neutral-900 flex items-center gap-3">
      <span class="w-2 h-8 bg-primary-600 rounded-full"></span>
      経歴・タイムライン
    </h2>
    <div class="flex-grow h-px bg-neutral-200/60"></div>
  </div>

  <div
    class="relative space-y-12 before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-neutral-200 before:to-transparent"
  >
    {
      sortedBackgrounds.length > 0 ? (
        sortedBackgrounds.map(background => (
          <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group">
            {/* アイコン（点） */}
            <div class="flex items-center justify-center w-10 h-10 rounded-full border-4 border-neutral-50 bg-white group-hover:bg-primary-600 group-hover:text-white text-neutral-400 shadow-sm shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 transition-all duration-500 z-10">
              <Icon name="heroicons:calendar-days" class="w-5 h-5" />
            </div>

            {/* コンテンツカード */}
            <div class="w-[calc(100%-4rem)] md:w-[45%] p-8 rounded-[2rem] bg-white/70 backdrop-blur-sm border border-neutral-200/60 shadow-sm hover:shadow-2xl hover:shadow-primary-500/5 hover:border-primary-200 transition-all duration-500 md:group-odd:text-right">
              <div class="flex flex-col space-y-3">
                <time class="font-bold text-primary-600/80 text-xs tracking-[0.2em] uppercase">
                  {new Date(background.eventDate).toLocaleDateString("ja-JP", {
                    year: "numeric",
                    month: "long",
                  })}
                </time>
                <h3 class="text-2xl font-black text-neutral-900 group-hover:text-primary-600 transition-colors leading-tight">
                  {background.title}
                </h3>
                {background.description && (
                  <p class="text-neutral-500 text-sm leading-relaxed md:group-odd:ml-auto">
                    {background.description}
                  </p>
                )}
                <div class="pt-6">
                  <a
                    href={`/about/${background.id}`}
                    class="inline-flex items-center gap-2 text-[10px] font-black text-neutral-400 hover:text-primary-600 transition-all uppercase tracking-[0.2em] group/link"
                  >
                    View Details
                    <Icon
                      name="heroicons:chevron-right"
                      class="w-3 h-3 group-hover/link:translate-x-1 transition-transform"
                    />
                  </a>
                </div>
              </div>
            </div>
          </div>
        ))
      ) : (
        <div class="text-center py-20 bg-white/50 backdrop-blur-sm rounded-[3rem] border border-neutral-100">
          <p class="text-neutral-400 font-bold">経歴データが見つかりませんでした。</p>
        </div>
      )
    }
  </div>
</div>
