---
import { Icon } from "astro-icon/components";
import { fetchBackgrounds } from "../services/fetchBackgrounds";

const backgrounds = await fetchBackgrounds();

// 日付でソート (降順)
const sortedBackgrounds = [...backgrounds].sort(
  (a, b) => new Date(b.eventDate).getTime() - new Date(a.eventDate).getTime()
);
---

<div class="max-w-4xl mx-auto">
  <div class="flex items-center gap-4 mb-12">
    <h2 class="text-3xl font-black text-neutral-900 flex items-center gap-3">
      <span class="w-2 h-8 bg-blue-600 rounded-full"></span>
      経歴・タイムライン
    </h2>
    <div class="flex-grow h-px bg-neutral-100"></div>
  </div>

  <div
    class="relative space-y-8 before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-neutral-200 before:to-transparent"
  >
    {
      sortedBackgrounds.length > 0 ? (
        sortedBackgrounds.map(background => (
          <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active">
            {/* アイコン（点） */}
            <div class="flex items-center justify-center w-10 h-10 rounded-full border border-white bg-neutral-100 group-hover:bg-blue-600 group-hover:text-white text-neutral-400 shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 transition-all duration-500 z-10">
              <Icon name="heroicons:calendar-days" class="w-5 h-5" />
            </div>

            {/* コンテンツカード */}
            <div class="w-[calc(100%-4rem)] md:w-[45%] p-6 rounded-3xl bg-white border border-neutral-100 shadow-sm hover:shadow-xl hover:shadow-blue-500/5 transition-all duration-500 md:group-odd:text-right">
              <div class="flex flex-col space-y-2">
                <time class="font-black text-blue-600 text-sm tracking-widest uppercase">
                  {new Date(background.eventDate).toLocaleDateString("ja-JP", {
                    year: "numeric",
                    month: "long",
                  })}
                </time>
                <h3 class="text-xl font-black text-neutral-900 group-hover:text-blue-600 transition-colors">
                  {background.title}
                </h3>
                {background.description && (
                  <p class="text-neutral-500 text-sm line-clamp-2 md:group-odd:ml-auto">
                    {background.description}
                  </p>
                )}
                <div class="pt-4">
                  <a
                    href={`/about/${background.id}`}
                    class="inline-flex items-center gap-1 text-xs font-bold text-neutral-400 hover:text-blue-600 transition-colors uppercase tracking-widest"
                  >
                    View Details
                    <Icon name="heroicons:chevron-right" class="w-3 h-3" />
                  </a>
                </div>
              </div>
            </div>
          </div>
        ))
      ) : (
        <div class="text-center py-20 bg-neutral-50 rounded-[2.5rem] border-2 border-dashed border-neutral-100">
          <p class="text-neutral-400 font-bold">経歴データが見つかりませんでした。</p>
        </div>
      )
    }
  </div>
</div>
