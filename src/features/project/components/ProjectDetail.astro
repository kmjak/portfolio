---
import { Icon } from "astro-icon/components";
import type { ProjectDetailed } from "../types/Project";

interface Props {
  project: ProjectDetailed;
}

const { project } = Astro.props;
---

<article class="max-w-5xl mx-auto space-y-12 py-8">
  <!-- ナビゲーション -->
  <nav>
    <a
      href="/projects"
      class="group inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white border border-neutral-200 text-neutral-600 hover:text-blue-600 hover:border-blue-200 hover:shadow-sm transition-all duration-300 font-medium text-sm"
    >
      <Icon
        name="heroicons:arrow-left"
        class="w-4 h-4 group-hover:-translate-x-1 transition-transform"
      />
      一覧へ戻る
    </a>
  </nav>

  <!-- メインヘッダーカード -->
  <div
    class="relative overflow-hidden rounded-3xl bg-white border border-neutral-100 shadow-xl shadow-neutral-200/50"
  >
    <div class="p-8 md:p-12 space-y-8">
      <header class="space-y-6">
        <div class="space-y-4">
          <h1 class="text-4xl md:text-5xl font-black text-neutral-900 tracking-tight leading-tight">
            {project.title}
          </h1>
          <p class="text-xl text-neutral-500 leading-relaxed max-w-3xl font-medium">
            {project.description}
          </p>
        </div>

        <div class="flex flex-wrap gap-4 pt-4">
          {
            project.repoUrl && (
              <a
                href={project.repoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-neutral-900 text-white hover:bg-neutral-800 transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5"
              >
                <Icon name="mdi:github" class="w-5 h-5" />
                <span class="font-bold text-sm">View Source</span>
              </a>
            )
          }
          {
            project.demoUrl && (
              <a
                href={project.demoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-blue-600 text-white hover:bg-blue-500 transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5"
              >
                <Icon name="heroicons:bolt" class="w-5 h-5" />
                <span class="font-bold text-sm">Live Demo</span>
              </a>
            )
          }
        </div>
      </header>

      {
        project.thumbnailUrl && (
          <div class="rounded-2xl overflow-hidden border border-neutral-100 shadow-inner bg-neutral-50">
            <img
              src={project.thumbnailUrl}
              alt={project.title}
              class="w-full h-auto object-cover transform hover:scale-[1.02] transition-transform duration-700"
            />
          </div>
        )
      }

      {
        project.detail && (
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-x-12 gap-y-10 pt-8 border-t border-neutral-100">
            <section class="space-y-3">
              <h2 class="text-xl font-bold text-neutral-900 flex items-center gap-2">
                <span class="w-1 h-6 bg-blue-600 rounded-full" />
                プロジェクトの背景
              </h2>
              <p class="text-neutral-600 leading-relaxed whitespace-pre-wrap">
                {project.detail.background}
              </p>
            </section>

            <section class="space-y-3">
              <h2 class="text-xl font-bold text-neutral-900 flex items-center gap-2">
                <span class="w-1 h-6 bg-blue-600 rounded-full" />
                注力ポイント
              </h2>
              <p class="text-neutral-600 leading-relaxed whitespace-pre-wrap">
                {project.detail.keyPoints}
              </p>
            </section>

            <section class="space-y-3">
              <h2 class="text-xl font-bold text-neutral-900 flex items-center gap-2">
                <span class="w-1 h-6 bg-blue-600 rounded-full" />
                直面した課題
              </h2>
              <p class="text-neutral-600 leading-relaxed whitespace-pre-wrap">
                {project.detail.challenges}
              </p>
            </section>

            <section class="space-y-3">
              <h2 class="text-xl font-bold text-neutral-900 flex items-center gap-2">
                <span class="w-1 h-6 bg-blue-600 rounded-full" />
                解決策・成果
              </h2>
              <p class="text-neutral-600 leading-relaxed whitespace-pre-wrap">
                {project.detail.solutions}
              </p>
            </section>
          </div>
        )
      }
    </div>
  </div>

  <!-- スキルセクション -->
  {
    project.skills.length > 0 && (
      <section class="space-y-8">
        <div class="flex items-center gap-4">
          <h2 class="text-3xl font-black text-neutral-900 flex items-center gap-3">
            <span class="w-2 h-8 bg-blue-600 rounded-full" />
            使用技術
          </h2>
          <div class="flex-grow h-px bg-neutral-100" />
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
          {project.skills.map(skill => (
            <div class="group relative p-5 bg-white border border-neutral-100 rounded-2xl shadow-sm hover:shadow-xl hover:shadow-blue-500/5 hover:-translate-y-1 transition-all duration-300 overflow-hidden text-center">
              <div class="relative space-y-3">
                <h3 class="text-lg font-bold text-neutral-800 group-hover:text-blue-600 transition-colors duration-300 tracking-tight">
                  {skill.name}
                </h3>

                {skill.categories && skill.categories.length > 0 && (
                  <div class="flex flex-wrap justify-center gap-1">
                    {skill.categories.map(cat => (
                      <span class="text-[8px] px-1.5 py-0.5 bg-neutral-50 text-neutral-400 border border-neutral-100 rounded-md font-black uppercase tracking-widest">
                        {cat.name}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </section>
    )
  }
</article>
