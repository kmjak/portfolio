---
import { Icon } from "astro-icon/components";
import { fetchProjects } from "../services/fetchProjects";
import type { Project } from "../types/Project";

const projects = await fetchProjects();
---

<div class="max-w-6xl mx-auto px-4">
  <div class="flex items-center gap-4 mb-12">
    <h2 class="text-3xl font-black text-neutral-900 flex items-center gap-3">
      <span class="w-2 h-8 bg-primary-600 rounded-full"></span>
      プロジェクト一覧
    </h2>
    <div class="flex-grow h-px bg-neutral-100"></div>
  </div>

  {
    projects.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((project: Project) => (
          <a href={`/projects/${project.id}`} class="group block h-full">
            <article class="flex flex-col h-full bg-white/70 backdrop-blur-sm border border-neutral-200/60 rounded-3xl overflow-hidden hover:shadow-2xl hover:shadow-primary-500/10 hover:border-primary-200 transition-all duration-500">
              <div class="aspect-video w-full bg-neutral-100 relative overflow-hidden">
                {project.thumbnailUrl ? (
                  <img 
                    src={project.thumbnailUrl} 
                    alt={project.title} 
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-primary-50 to-fuchsia-50">
                    <Icon name="mdi:folder-outline" class="w-12 h-12 text-neutral-300" />
                  </div>
                )}
                <div class="absolute top-4 right-4 flex gap-2">
                  {project.repoUrl && (
                    <div class="p-2 bg-white/90 backdrop-blur rounded-full shadow-sm text-neutral-600 hover:text-primary-600 transition-colors">
                      <Icon name="mdi:github" class="w-4 h-4" />
                    </div>
                  )}
                </div>
              </div>
              
              <div class="flex flex-col flex-grow p-6">
                <h3 class="text-xl font-bold text-neutral-900 mb-3 group-hover:text-primary-600 transition-colors line-clamp-1">
                  {project.title}
                </h3>
                <p class="text-neutral-500 text-sm line-clamp-3 mb-6 leading-relaxed flex-grow">
                  {project.description}
                </p>
                
                <div class="flex items-center justify-between pt-4 border-t border-neutral-100 mt-auto">
                  <span class="text-xs font-bold text-neutral-400 uppercase tracking-widest group-hover:text-primary-600 transition-colors">
                    View Project
                  </span>
                  <Icon name="mdi:arrow-right" class="w-5 h-5 text-neutral-300 group-hover:text-primary-600 group-hover:translate-x-1 transition-all" />
                </div>
              </div>
            </article>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-20 bg-white/50 backdrop-blur-sm rounded-[2.5rem] border border-neutral-100">
        <p class="text-neutral-400 font-bold">プロジェクトが見つかりませんでした。</p>
      </div>
    )
  }
</div>
