---
import Card from "@/shared/components/card/Card.astro";
import { fetchProjects } from "../services/fetchProjects";
import type { Project } from "../types/Project";

const projects = await fetchProjects();
---

<Card iconName="mdi:folder-multiple-outline" cardTitle="プロジェクト">
  {
    projects.length > 0 ? (
      <ul class="space-y-4">
        {projects.map((project: Project) => (
          <a href={`/projects/${project.id}`} class="block">
            <Card hasHeader={false}>
              <li>
                <p class="text-xl font-semibold mb-2">{project.title}</p>
                <p class="text-sm text-gray-600 mb-3">{project.description}</p>
                <div class="flex gap-2 flex-wrap">
                  {project.repoUrl && (
                    <a
                      href={project.repoUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded hover:bg-blue-200"
                    >
                      Repo
                    </a>
                  )}
                  {project.demoUrl && (
                    <a
                      href={project.demoUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded hover:bg-green-200"
                    >
                      Demo
                    </a>
                  )}
                </div>
              </li>
            </Card>
          </a>
        ))}
      </ul>
    ) : (
      <p class="text-center text-gray-500">プロジェクトがありません。</p>
    )
  }
</Card>
