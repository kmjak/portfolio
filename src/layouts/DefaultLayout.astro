---
import { HamburgerSection } from "@/features/navigation/components/hamburger";
import Sidebar from "@/features/navigation/components/sidebar/Sidebar.astro";
import Separator from "@/shared/components/starwind/separator/Separator.astro";
import "@/styles/global.css";
import "@/styles/starwind.css";

interface Props {
  title: string;
  heading?: string;
  className?: string;
  description?: string;
}

const {
  title,
  heading = null,
  className = "",
  description = `kmjakのポートフォリオサイトです。Web開発に関するブログ記事や、連絡先・経歴などを掲載しています。`,
} = Astro.props;
const currentPath = Astro.url.pathname;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/icon.jpg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="keywords" content="ポートフォリオ, エンジニア, kmjak, ブログ, Web開発" />
    <meta name="author" content="kmjak" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL("/icon.jpg", Astro.url).toString()} />
    <title>kmjak | {title}</title>
  </head>
  <body>
    <div class="flex h-screen w-screen">
      <Sidebar />
      <Separator orientation="vertical" class="mx-2 h-screen w-px bg-neutral-300 hidden lg:flex" />
      <main class="flex-1 min-h-screen overflow-y-scroll bg-transparent">
        {
          heading !== null && (
            <div class="sticky top-0 z-20 bg-white/70 backdrop-blur-md border-b border-neutral-200/50">
              <div class="flex justify-between items-center px-6 md:px-12 py-4 md:py-6">
                <h1 class="text-2xl md:text-3xl font-extrabold text-neutral-900 tracking-tight">
                  {heading}
                </h1>
                <HamburgerSection client:media="(max-width: 1023px)" currentPath={currentPath} />
              </div>
            </div>
          )
        }
        <div class={`w-11/12 max-w-7xl mx-auto py-8 md:py-12 ${className}`}>
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>
