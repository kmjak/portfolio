---
import { fetchSkills } from "@/features/project/services/fetchSkills";
import DefaultLayout from "src/layouts/DefaultLayout.astro";

const skills = await fetchSkills();

// カテゴリごとにスキルをグループ化
const skillsByCategory = skills.reduce(
  (acc, skill) => {
    if (skill.categories.length === 0) {
      const others = "その他";
      if (!acc[others]) {
        acc[others] = [];
      }
      acc[others].push(skill);
    } else {
      skill.categories.forEach(category => {
        if (!acc[category.name]) {
          acc[category.name] = [];
        }
        acc[category.name].push(skill);
      });
    }
    return acc;
  },
  {} as Record<string, typeof skills>
);

const title = "Skills";
const heading = "スキルセット";
---

<DefaultLayout title={title} heading={heading}>
  <div class="max-w-5xl mx-auto px-4 py-12 space-y-16">
    <section class="space-y-4">
      <p class="text-xl text-neutral-500 font-medium [text-wrap:pretty]">
        <span class="inline-block">これまでに触れてきた技術スタックを</span><span class="inline-block">カテゴリ別にまとめています。</span><span class="inline-block">実務や個人開発での経験に基づいています。</span>
      </p>
    </section>

    {
      Object.entries(skillsByCategory).map(([categoryName, categorySkills]) => (
        <section class="space-y-8">
          <div class="flex items-center gap-4">
            <h2 class="text-2xl font-black text-neutral-900 flex items-center gap-3">
              <span class="w-1.5 h-7 bg-blue-600 rounded-full" />
              {categoryName}
            </h2>
            <div class="flex-grow h-px bg-neutral-100" />
            <span class="text-sm font-bold text-neutral-400 tabular-nums">
              {categorySkills.length} SKILLS
            </span>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {categorySkills.map(skill => (
              <div class="group p-6 bg-white border border-neutral-100 rounded-2xl shadow-sm hover:shadow-xl hover:shadow-blue-500/5 hover:-translate-y-1 transition-all duration-300">
                <div class="space-y-4">
                  <div class="flex justify-between items-start">
                    <h3 class="text-lg font-bold text-neutral-800 group-hover:text-blue-600 transition-colors">
                      {skill.name}
                    </h3>
                    <div class="flex items-center gap-1.5">
                      <span class="text-xs font-black text-blue-600/40 tabular-nums">LV.</span>
                      <span class="text-lg font-black text-blue-600 tabular-nums leading-none">
                        {skill.level}
                      </span>
                    </div>
                  </div>

                  {/* レベルゲージ */}
                  <div class="h-1.5 w-full bg-neutral-100 rounded-full overflow-hidden">
                    <div
                      class="h-full bg-blue-600 rounded-full transition-all duration-1000 ease-out group-hover:bg-blue-500"
                      style={`width: ${skill.level * 10}%`}
                    />
                  </div>

                  {skill.description && (
                    <p class="text-sm text-neutral-500 leading-relaxed line-clamp-2 group-hover:line-clamp-none transition-all [overflow-wrap:anywhere]">
                      {skill.description}
                    </p>
                  )}
                </div>
              </div>
            ))}
          </div>
        </section>
      ))
    }

    {
      Object.keys(skillsByCategory).length === 0 && (
        <div class="text-center py-20">
          <p class="text-neutral-400 font-medium">スキルデータが見つかりませんでした。</p>
        </div>
      )
    }
  </div>
</DefaultLayout>
