---
import { Icon } from "astro-icon/components";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<li
  class="group flex items-center justify-between text-sm font-medium text-neutral-700 py-4 px-5 rounded-xl border border-neutral-200/60 bg-white/50 hover:bg-white hover:border-primary-200 hover:text-primary-700 transition-all duration-300 shadow-sm hover:shadow-md"
>
  <span class="line-clamp-1">{title}</span>
  <Icon name="mdi:chevron-right" class="w-5 h-5 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300" />
</li>
